# Python build artifacts
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/

# Local runtime / work dirs
.knotliedge/

# Secrets (API keys / local overrides)
.env

# Extra local data trees (not part of minimal public README layout)
data/article_workspace/
data/06_metadata/
data/07_venue_radar/

# Alternate folder name (legacy skills / templates); public docs live in README only
doc/

# Conda/OpenCL vendor scratch files (should not live in repo)
.opencl_vendors/

# Root scratch scripts (local one-offs)
tmp_*.py

# Local corpus, vault, Chroma persistence (keep only .gitkeep placeholders)
data/01_raw_pdf/**
