!data/02_markdown_vault/assets/.gitkeep
data/03_chroma_db/**
!data/03_chroma_db/.gitkeep

# Generated reports / workflow artifacts
output/**
!output/.gitkeep

# Sandbox runtime data (configs under sandbox/configs/ remain tracked)
sandbox/data/

# Embedding weights (download locally, e.g. ModelScope BGE-M3)
models/

# Local SQLite stores (FTS / radar / citation graphs when created under repo root or data paths)
*.sqlite3

# Internal / agent-oriented docs (not published with public snapshot)
docs/
