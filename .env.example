# Copy to ".env" in the repo root (".env" is gitignored).
#
# Default stack matches Aliyun DashScope **OpenAI-compatible** Chat Completions
# (see AliAIPlatfor.md): base_url https://dashscope.aliyuncs.com/compatible-mode/v1
# and model qwen-plus unless overridden.
#
# Primary key name per Alibaba docs:
DASHSCOPE_API_KEY=

# Alternative if you call api.openai.com instead (set OPENAI_BASE_URL accordingly):
# OPENAI_API_KEY=

# Optional overrides:
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Singapore: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-plus
# DASHSCOPE_MODEL=qwen-plus

# Fast translation-only key (used by templates/openai_chat/quick_translate_en.json)
QUICK_TRANSLATE_API_KEY=
